# API base URL.
# Dev default is the relative path "/api" (proxy/same-origin friendly).
# In production this MUST be an absolute https:// URL — the env schema rejects
# plain http:// in prod because the bearer token rides in the Authorization header.
VITE_API_URL=/api

# Public-facing app URL (used for SEO canonical tags, OG meta).
# Optional in dev (falls back to window.location.origin); set it in production.
VITE_APP_URL=https://example.com
